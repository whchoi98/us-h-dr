# =============================================================================
# DR Lab Demo Environment Configuration
# Copy to demo.env and fill in values from Terraform/CDK outputs
# =============================================================================

# OnPrem VPC (us-west-2)
ONPREM_EKS_CLUSTER="onprem-eks"
ONPREM_PG_HOST=""          # OnPrem PostgreSQL private IP
ONPREM_MONGO_HOST=""       # OnPrem MongoDB private IP
ONPREM_KAFKA_BROKERS=""    # OnPrem Kafka broker:9092 addresses (comma-separated)
ONPREM_DEBEZIUM_HOST=""    # Debezium Connect private IP
ONPREM_CF_DOMAIN=""        # OnPrem CloudFront distribution domain

# US-W VPC (us-west-2)
USW_MONGO_HOST=""          # US-W MongoDB private IP
USW_MSK_BROKERS=""         # US-W MSK bootstrap brokers (IAM, port 9098)
USW_DSQL_ENDPOINT=""       # Aurora DSQL primary endpoint

# US-E VPC (us-east-1) — DR
USE_MONGO_HOST=""          # US-E MongoDB private IP
USE_MSK_BROKERS=""         # US-E MSK bootstrap brokers (IAM, port 9098)
USE_DSQL_ENDPOINT=""       # Aurora DSQL linked endpoint

# Demo Settings
PG_USER="debezium"
PG_DB="ecommerce"
MONGO_DB="ecommerce"
DEMO_RECORD_COUNT=100      # Records per table (small for demo, 100-1000)
